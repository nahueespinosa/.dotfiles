[alias]
  sweep = "!git fetch --prune && branches=$(git for-each-ref --format='%(if:equals=gone)%(upstream:track,nobracket)%(then)%(refname:short)%(end)' refs/heads/) && if [ -z \"$branches\" ]; then echo 'Clean! No gone branches to delete.'; else git branch --delete --force $branches; fi"
[core]
  pager = cat
  editor = vim
[diff]
  mnemonicPrefix = true
[log]
  abbrevCommit = true
[push]
  autoSetupRemote = true
  default = current
[init]
  defautlBranch = main
