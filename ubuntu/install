#!/usr/bin/env bash
set -euo pipefail

# Logging
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }
err() { echo "[ERROR] $*" >&2; exit 1; }

# Validation
[[ $EUID -eq 0 ]] || err "Script must be run with sudo"
[[ -n "$(command -v lsb_release)" ]] || err "lsb_release not found"

# Single apt update
log "Updating package lists..."
sudo apt-get update

# Install common packages
log "Installing common packages..."
sudo apt-get install -y --no-install-recommends \
  apt-transport-https \
  build-essential \
  ca-certificates \
  curl \
  cmake \
  git \
  gnupg \
  htop \
  lsb-release \
  mesa-utils \
  ncdu \
  python3 \
  python3-dev \
  python3-venv \
  software-properties-common \
  tmux \
  vim \
  vim-gtk3

# Docker (using official script)
log "Installing Docker..."
curl -fsSL https://get.docker.com -o /tmp/get-docker.sh
sudo bash /tmp/get-docker.sh
sudo usermod -aG docker "$USER"
log "Docker installed. You may need to log out and back in."

# VS Code (stable repository)
log "Installing VS Code..."
sudo apt-get install -y wget gpg
wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor | sudo tee /usr/share/keyrings/packages.microsoft.gpg > /dev/null
echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main" | sudo tee /etc/apt/sources.list.d/vscode.list > /dev/null
sudo apt-get update
sudo apt-get install -y code

# Dive (latest release)
log "Installing Dive..."
DIVE_VERSION=$(curl -s https://api.github.com/repos/wagoodman/dive/releases/latest | grep tag_name | cut -d'"' -f4)
curl -L "https://github.com/wagoodman/dive/releases/download/${DIVE_VERSION}/dive_${DIVE_VERSION:1}_linux_amd64.deb" -o /tmp/dive.deb
sudo apt-get install -y /tmp/dive.deb

log "Setup complete!"
